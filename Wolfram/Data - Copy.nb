Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"reasoningByCategory", "=", 
   RowBox[{
    RowBox[{"Query", "[", 
     RowBox[{
      RowBox[{"GroupBy", "[", "\"\<category\>\"", "]"}], ",", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<mean\>\"", "->", 
         RowBox[{"(", "Mean", ")"}]}], ",", 
        RowBox[{"\"\<std\>\"", "->", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Length", "[", "#", "]"}], ">", "1"}], ",", 
             RowBox[{"StandardDeviation", "[", "#", "]"}], ",", "0."}], "]"}],
            "&"}], ")"}]}], ",", 
        RowBox[{"\"\<count\>\"", "->", "Length"}]}], "|>"}], 
      ",", "\"\<reasoning_markers\>\""}], "]"}], "[", "dataWithMarkers", 
    "]"}]}], ";"}], "\n", 
 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Query", "[", 
     RowBox[{"All", ",", "\"\<mean\>\""}], "]"}], "@", 
    "reasoningByCategory"}], ",", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"Expression", "SequenceIcon", 
       GridBox[{{
          RowBox[{
            TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["Sequence", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["5", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["440", "IconizedItem"]}]}}, 
        GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
        "Column", 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
       Dynamic[Typeset`open]},
      "IconizedObject"]],
    Sequence[
    ChartLabels -> Automatic, PlotLabel -> 
     "Average Reasoning Markers per Response", BaseStyle -> Bold, GridLines -> 
     Automatic, ImageSize -> 500],
    SelectWithContents->True,
    Selectable->False]}], "]"}]}], "Input",
