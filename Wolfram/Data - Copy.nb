Cell[CellGroupData[{

Cell["Prompt embeddings clustering", "Section",
 CellChangeTimes->{
  3.981956237416424*^9, {3.981956362471651*^9, 
   3.981956374408762*^9}},ExpressionUUID->"9f41db71-6e68-5b4c-9dbb-\
17c90029bf88"],

Cell["\<\
When you send prompts to a Large Language Model (LLM), it converts those text \
inputs into \[OpenCurlyDoubleQuote]embeddings\[CloseCurlyDoubleQuote]\
\[LongDash]massive lists of numbers (often thousands of dimensions long) that \
represent the mathematical \[OpenCurlyDoubleQuote]meaning\
\[CloseCurlyDoubleQuote] of the text.\
\>", "Text",
 CellChangeTimes->{{3.981956875384247*^9, 3.9819568899828663`*^9}, {
   3.981957140210655*^9, 3.981957147398485*^9}, {3.9819572010306263`*^9, 
   3.9819572050320377`*^9}, 3.9819572950916386`*^9, 
   3.981957873608017*^9},ExpressionUUID->"0098dd7e-ec9c-ab43-a616-\
4dafcbf07c76"],

Cell["\<\
As humans we cannot comprehend 1,000-dimensional space, we use UMAP (Uniform \
Manifold Approximation and Projection). UMAP is a dimensionality reduction \
algorithm that squashes those thousands of dimensions down to just two (the X \
and Y axes you see here). Crucially, UMAP preserves local structure: if two \
prompts mean similar things or trigger similar internal model behavior, they \
will fall in the same cluster.\
\>", "Text",
 CellChangeTimes->{{3.981956875384247*^9, 3.9819568899828663`*^9}, {
   3.981957140210655*^9, 3.981957147398485*^9}, {3.9819572010306263`*^9, 
   3.9819572050320377`*^9}, 3.9819572950916386`*^9, {3.981957958207199*^9, 
   3.98195796350729*^9}},ExpressionUUID->"b44e8c7f-e866-684c-88e7-\
32424355ed29"],

Cell["Let\[CloseCurlyQuote]s start by extracting relevant values from the \
data", "Text",
 CellChangeTimes->{{3.9819576711654797`*^9, 
  3.981957698729555*^9}},ExpressionUUID->"99e9c9cb-ae19-6b43-bf83-\
1ceb06e9c07f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"prompts", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"data", "[", 
     RowBox[{"All", ",", "\"\<prompt\>\""}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"responses", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"data", "[", 
     RowBox[{"All", ",", "\"\<response\>\""}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"categories", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"data", "[", 
     RowBox[{"All", ",", "\"\<category\>\""}], "]"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9819577041029606`*^9, 3.9819577041029606`*^9}},
 CellLabel->"In[32]:=",ExpressionUUID->"db0f148b-4152-2e47-887a-a1a3eddbb909"],

Cell[TextData[{
 "Then generate the embeddings. ",
 StyleBox["FeatureExtract", "Code"],
 " handles state-of-the-art text embeddings natively, ",
 StyleBox["DimensionReduce", "Code"],
 " supports UMAP. These embedding may not be exactly what different LLMs use, \
but they are close enough to study."
}], "Text",
 CellChangeTimes->{{3.981957709997553*^9, 3.9819577172802906`*^9}, {
  3.9819579209772453`*^9, 3.9819579420613537`*^9}, {3.981959826578968*^9, 
  3.981959866415886*^9}},ExpressionUUID->"4646780d-e091-614d-9058-\
db46995924e7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"promptEmbeddings", "=", 
   RowBox[{"FeatureExtract", "[", 
    RowBox[{"prompts", ",", "\"\<SentenceVector\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"responseEmbeddings", "=", 
   RowBox[{"FeatureExtract", "[", 
    RowBox[{"responses", ",", "\"\<SentenceVector\>\""}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.981957989177635*^9, 3.981957989177635*^9}, {
  3.9819585203386707`*^9, 3.9819585244327393`*^9}},
 CellLabel->"In[38]:=",ExpressionUUID->"47f09218-61a2-f34e-87ab-e3025c7ef536"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Column", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Dimensions", "@", "promptEmbeddings"}], ",", 
    RowBox[{"Dimensions", "@", "responseEmbeddings"}]}], "}"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.9819585379526234`*^9, 3.981958541332773*^9}, {
  3.981958583900028*^9, 3.9819585988525677`*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"a0361aac-9431-7849-8c4f-eb501cbc0d77"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     RowBox[{"{", 
      RowBox[{"400", ",", "384"}], "}"}]},
