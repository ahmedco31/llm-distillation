       Sequence[
       PlotRange -> All, PlotLabel -> 
        Style["Anomaly Detection: Latency vs Token Count", 16], 
        AxesLabel -> {"Total Tokens", "Latency (ms)"}, PlotTheme -> 
        "Detailed", ImageSize -> 600, BaseStyle -> Bold],
       SelectWithContents->True,
       Selectable->False]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
