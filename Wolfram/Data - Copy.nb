  RowBox[{"anomalyColors", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"False", "->", "nativeBlue"}], ",", 
     RowBox[{"True", "->", "nativeRed"}]}], "|>"}]}], ";"}]}], "Input",
