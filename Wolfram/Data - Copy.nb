 CellChangeTimes->{{3.9817469922778435`*^9, 3.9817470318060207`*^9}, 
   3.9817474324751396`*^9, {3.981747546023237*^9, 3.9817475760810566`*^9}},
 CellLabel->"Out[51]=",ExpressionUUID->"93e711cb-17e3-044b-be6b-392fb423f77e"]
}, Open  ]],

Cell["\<\
The heavily right-skewed distribution of response lengths is characteristic \
of a diverse query dataset aiming for broad domain coverage. Expected \
distillation behaviour. The boxplot shows how the word count is being \
distributed across the categories.\
\>", "Text",
 CellChangeTimes->{{3.981746853736536*^9, 
  3.9817468808756504`*^9}},ExpressionUUID->"ad750bf2-ae91-ca43-ab00-\
fc87b777e575"],

Cell[CellGroupData[{

Cell["Reasoning pattern detection", "Section",
 CellChangeTimes->{
  3.9817476676989574`*^9},ExpressionUUID->"bd3c9efe-924c-e94f-a1b7-\
61117635d044"],

Cell["\<\
Distilling a model\[CloseCurlyQuote]s step-by-step reasoning process \
(Chain-of-Thought or CoT) is highly desirable because it allows an attacker \
to extract not just the final answer, but the underlying logic and \
problem-solving methodology of the target model. By tracking these markers, \
API providers can build anomaly detection systems to identify systematic \
queries designed to elicit these expensive reasoning chains, which strongly \
indicates a model extraction attack is occurring.\
\>", "Text",
 CellChangeTimes->{
  3.981747674180174*^9},ExpressionUUID->"526d508b-bc82-e446-bef7-\
0ce95926848a"],

Cell["\<\
The bar chart below shows the average count of reasoning markers (like \
\[OpenCurlyDoubleQuote]first,\[CloseCurlyDoubleQuote] \
\[OpenCurlyDoubleQuote]then,\[CloseCurlyDoubleQuote] \
\[OpenCurlyDoubleQuote]therefore,\[CloseCurlyDoubleQuote] \
\[OpenCurlyDoubleQuote]step-by-step\[CloseCurlyDoubleQuote]) per response, \
grouped by category. High usage of reasoning markers in \
\[OpenCurlyDoubleQuote]math_basic\[CloseCurlyDoubleQuote], \
\[OpenCurlyDoubleQuote]code_simple\[CloseCurlyDoubleQuote], and \
\[OpenCurlyDoubleQuote]abstract\[CloseCurlyDoubleQuote] queries is shown.\
\>", "Text",
 CellChangeTimes->{
  3.981747683392164*^9},ExpressionUUID->"b4030583-4511-0d40-8bf9-\
34969e60c8aa"],

Cell["Define markers and counting function", "Text",
 CellChangeTimes->{{3.9817482313582306`*^9, 
  3.981748244870676*^9}},ExpressionUUID->"bb2b28e4-8dfc-3f48-be1e-\
8d85c718dbec"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"reasoningMarkers", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
     "RegularExpression", 
      "[", "\"\<\\\\b(first|second|third|finally|therefore|thus|hence)\\\\b\>\
\"", "]"}], ",", 
     RowBox[{
     "RegularExpression", "[", "\"\<\\\\b(step \\\\d+|step-by-step)\\\\b\>\"",
       "]"}], ",", 
     RowBox[{
     "RegularExpression", "[", "\"\<\\\\b(because|since|given that)\\\\b\>\"",
       "]"}], ",", 
     RowBox[{
     "RegularExpression", "[", "\"\<\\\\d+[\\\\.\\\\)]\\\\s\>\"", "]"}]}], 
    "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"countMarkers", "[", "text_String", "]"}], ":=", 
   RowBox[{"Total", "[", 
    RowBox[{"StringCount", "[", 
     RowBox[{"text", ",", "reasoningMarkers", ",", 
      RowBox[{"IgnoreCase", "->", "True"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"countMarkers", "[", "_", "]"}], ":=", "0"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9817478011299706`*^9, 3.9817478011299706`*^9}, {
   3.9817480304137707`*^9, 3.981748031129612*^9}, 3.9817481744242134`*^9},
 CellLabel->"In[53]:=",ExpressionUUID->"d7d35350-bdc9-7447-97c5-6523b8c9bb66"],

Cell["Add the counts to the data", "Text",
 CellChangeTimes->{{3.981748273827877*^9, 
  3.9817482790592575`*^9}},ExpressionUUID->"45536c80-dc72-9740-8582-\
b414305d6062"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"dataWithMarkers", "=", 
   RowBox[{"InsertColumns", "[", 
    RowBox[{"data", ",", 
     RowBox[{"\"\<reasoning_markers\>\"", "->", 
      RowBox[{"TabularColumn", "[", 
       RowBox[{"countMarkers", "/@", 
        RowBox[{"Normal", "[", 
         RowBox[{"data", "[", 
          RowBox[{"All", ",", "\"\<response\>\""}], "]"}], "]"}]}], "]"}]}]}],
     "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Tabular", "[", 
  RowBox[{"dataWithMarkers", ",", 
   RowBox[{"Background", "->", 
    RowBox[{"<|", 
     RowBox[{"\"\<ColumnRules\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<reasoning_markers\>\"", "->", 
        TemplateBox[<|"color" -> RGBColor[0.24, 0.6, 0.8]|>,
         "RGBColorSwatchTemplate"]}], "}"}]}], "|>"}]}], ",", 
   RowBox[{"ImageSize", "->", "Medium"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9817484936095066`*^9, 3.9817485389236984`*^9}, {
  3.9817486370641613`*^9, 3.98174864511141*^9}, {3.9817487526275463`*^9, 
  3.981748804521446*^9}, {3.981749011634344*^9, 3.981749089828125*^9}, {
  3.9817491338194313`*^9, 3.981749150501026*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"71880286-52c9-a94e-ae4f-9a1dece0cebe"],

