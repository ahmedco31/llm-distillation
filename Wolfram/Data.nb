is_balanced(expression):\n    # Create a stack to keep track of opening \
brackets\n    stack = []\n    # Dictionary to map closing brackets to their \
corresponding opening brackets\n    bracket_map = {')': '(', '}': '{', ']': \
'['}\n    \n    # Traverse each character in the expression\n    for char in \
expression:\n        # If the character is an opening bracket, push it onto \
the stack\n        if char in bracket_map.values():\n            \
