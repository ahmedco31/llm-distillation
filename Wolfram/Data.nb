          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      PlotLabel -> Style["Anomaly Detection: Latency vs Token Count", 16], 
       AxesLabel -> {"Total Tokens", "Latency (ms)"}, PlotTheme -> "Detailed",
        ImageSize -> 600, BaseStyle -> Bold, PlotRange -> {All, 20000}],
      SelectWithContents->True,
      Selectable->False]}], "]"}], ",", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"List", "ListIcon", 
       GridBox[{{
