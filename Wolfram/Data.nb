\n    elif max_val == b:\n        h = (60 * ((r - g) / delta) + 240) % 360\n\n\
    # Calculate Saturation\n    s = 0 if max_val == 0 else (delta / max_val)\n\
\n    # Calculate Value\n    v = max_val\n\n    # Return HSV values, h in \
