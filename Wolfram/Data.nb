      dp[i][j] = max(dp[i - 1][j], dp[i][j - 1]) + matrix[i][j]\n\n    # The \
total maximum sum path is in dp[n-1][n-1]\n    max_sum = dp[n - 1][n - 1]\n\n \
   # Calculate the number of steps in the path\n    steps = (n - 1) * 2\n\n   \
