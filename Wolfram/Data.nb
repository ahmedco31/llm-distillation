longest_consecutive_subsequence(arr):\n    if not arr:\n        return 0\n\n  \
  num_set = set(arr)\n    max_length = 0\n\n    for num in num_set:\n        \
# Check if it's the start of a sequence\n        if num - 1 not in num_set:\n \
           current_length = 1\n            current_num = num\n\n            # \
