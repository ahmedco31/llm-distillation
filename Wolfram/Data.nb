Cell["Extract categories and group the word counts by them", "Text",
 CellChangeTimes->{
  3.9817467388397255`*^9},ExpressionUUID->"afb37bb3-bcda-2248-96a7-\
d4dc7bc9090d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"hist", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"wordCounts", ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["5", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["512", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      30, Frame -> True, FrameLabel -> {"Word Count", "Frequency"}, PlotLabel -> 
       "Response Length Distribution", BaseStyle -> Bold],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"groupedData", "=", 
   RowBox[{"GroupBy", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Normal", "[", 
         RowBox[{"data", "[", 
          RowBox[{"All", ",", "\"\<category\>\""}], "]"}], "]"}], ",", 
        "wordCounts"}], "}"}], "]"}], ",", 
     RowBox[{"First", "->", "Last"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"box", "=", 
   RowBox[{"BoxWhiskerChart", "[", 
    RowBox[{
     RowBox[{"Values", "[", "groupedData", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Outliers\>\"", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<MedianMarker\>\"", ",", "1", ",", 
         RowBox[{"Directive", "[", 
          RowBox[{"Thick", ",", "White"}], "]"}]}], "}"}]}], "}"}], ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["6", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["624", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      ChartLabels -> Keys[$CellContext`groupedData], Frame -> True, 
       FrameLabel -> {"Word Count", None}, PlotLabel -> 
       "Response Length by Category", BaseStyle -> Bold, BarOrigin -> Left],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}], "\n", 
 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"hist", ",", "box"}], "}"}], ",", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"Expression", "SequenceIcon", 
       GridBox[{{
          RowBox[{
            TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["Sequence", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["2", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["200", "IconizedItem"]}]}}, 
        GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
        "Column", 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
       Dynamic[Typeset`open]},
      "IconizedObject"]],
    Sequence[ImageSize -> 660, Spacings -> 20],
    SelectWithContents->True,
    Selectable->False]}], "]"}]}], "Input",
