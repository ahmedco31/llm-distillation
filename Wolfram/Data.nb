        "Column", 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
       Dynamic[Typeset`open]},
      "IconizedObject"]],
    {
     Placed[
      PointLegend[
       ConstantArray[Black, 5], 
       Keys[$CellContext`categoryShapes], LegendMarkers -> 
       Map[$CellContext`categoryShapes, 
         Keys[$CellContext`categoryShapes]], LegendLabel -> 
       Style["Category", Bold]], Right], 
     Placed[
      SwatchLegend[{$CellContext`nativeBlue, $CellContext`nativeRed}, {
       "Normal", "Anomaly"}, LegendLabel -> Style["Anomaly Status", Bold], 
       LegendFunction -> (
        Framed[#, Background -> White, FrameStyle -> Gray, RoundingRadius -> 
         5]& )], {0.89, 0.14}]},
    SelectWithContents->True,
    Selectable->False]}], "]"}]], "Input",
