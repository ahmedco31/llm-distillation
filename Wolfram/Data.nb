Cell[BoxData[{
 RowBox[{
  RowBox[{"responses", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"data", "[", 
     RowBox[{"All", ",", "\"\<response\>\""}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"wordCounts", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"StringSplit", "[", "#", "]"}], "]"}], "&"}], "/@", 
    "responses"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.981719076130764*^9, 3.981719076130764*^9}, {
  3.9817464399832535`*^9, 3.9817464413844986`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"71276141-453b-0f4c-9ed8-7d60a713ed8c"],

Cell["Extract categories and group the word counts by them", "Text",
 CellChangeTimes->{
  3.9817467388397255`*^9},ExpressionUUID->"afb37bb3-bcda-2248-96a7-\
d4dc7bc9090d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"hist", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"wordCounts", ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["5", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["512", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      30, Frame -> True, FrameLabel -> {"Word Count", "Frequency"}, PlotLabel -> 
       "Response Length Distribution", BaseStyle -> Bold],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"groupedData", "=", 
   RowBox[{"GroupBy", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Normal", "[", 
         RowBox[{"data", "[", 
          RowBox[{"All", ",", "\"\<category\>\""}], "]"}], "]"}], ",", 
        "wordCounts"}], "}"}], "]"}], ",", 
     RowBox[{"First", "->", "Last"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"box", "=", 
   RowBox[{"BoxWhiskerChart", "[", 
    RowBox[{
     RowBox[{"Values", "[", "groupedData", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Outliers\>\"", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<MedianMarker\>\"", ",", "1", ",", 
         RowBox[{"Directive", "[", 
          RowBox[{"Thick", ",", "White"}], "]"}]}], "}"}]}], "}"}], ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["6", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["624", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      ChartLabels -> Keys[$CellContext`groupedData], Frame -> True, 
       FrameLabel -> {"Word Count", None}, PlotLabel -> 
       "Response Length by Category", BaseStyle -> Bold, BarOrigin -> Left],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}], "\n", 
 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"hist", ",", "box"}], "}"}], ",", 
   RowBox[{"ImageSize", "->", "660"}], ",", 
   RowBox[{"Spacings", "->", "20"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9817466969809017`*^9, 3.981746719586252*^9}, {
  3.9817474895483665`*^9, 3.9817475132398434`*^9}, {3.981747545190878*^9, 
  3.9817475757439003`*^9}},
 CellLabel->"In[48]:=",ExpressionUUID->"9afc2a70-33ef-9c41-b505-c1bc2790a742"],

