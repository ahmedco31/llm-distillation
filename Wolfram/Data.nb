Cell[TextData[StyleBox["In the case of randomised intervals in gpt-4o",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.982093327738325*^9, 
  3.9820933543973274`*^9}},ExpressionUUID->"6c78138a-e559-274c-9c31-\
032eba77fd13"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"intervals", "=", 
   RowBox[{"Differences", "@", 
    RowBox[{"Sort", "@", 
     RowBox[{"N", "[", 
      RowBox[{"AbsoluteTime", "/@", 
       RowBox[{"Normal", "[", 
        RowBox[{"data4o", "[", 
         RowBox[{"All", ",", "\"\<timestamp\>\""}], "]"}], "]"}]}], 
      "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"medianInterval", "=", 
   RowBox[{"Median", "@", "intervals"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"latencies", "=", 
   RowBox[{"DeleteAnomalies", "@", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Normal", "[", 
        RowBox[{"data4o", "[", 
         RowBox[{"All", ",", "\"\<category\>\""}], "]"}], "]"}], ",", 
       RowBox[{"Normal", "[", 
        RowBox[{"data4o", "[", 
         RowBox[{"All", ",", "\"\<latency_ms\>\""}], "]"}], "]"}]}], "}"}], 
     "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"meanLatency", "=", 
   RowBox[{"Mean", "[", 
    RowBox[{"N", "@", "latencies"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lHist", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"intervals", ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["10", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["1536", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      30, PlotLabel -> "Inter-Query Intervals (Random, gpt-4o)", 
       AxesLabel -> {"Seconds Between Queries", "Frequency"}, ChartStyle -> 
       EdgeForm[Black], PlotTheme -> "Detailed", 
       GridLines -> {{$CellContext`medianInterval}, None}, GridLinesStyle -> 
       Directive[Red, Dashed, 
         Thickness[0.005]], BaseStyle -> Bold, ChartLegends -> Placed[
         LineLegend[{
           Directive[Red, Dashed]}, {"Median"}], {Right, Top}], ImageSize -> 
       300],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"latencyByCategory", "=", 
   RowBox[{"GroupBy", "[", 
    RowBox[{"latencies", ",", 
     RowBox[{"First", "->", "Last"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lBox", "=", 
   RowBox[{"BoxWhiskerChart", "[", 
    RowBox[{
     RowBox[{"Values", "[", "latencyByCategory", "]"}], ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["6", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["712", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      ChartLabels -> Keys[$CellContext`latencyByCategory], PlotLabel -> 
       "Response Latency by Category (gpt-4o)", 
       AxesLabel -> {"Category", "Latency (ms)"}, PlotTheme -> "Detailed", 
       BarOrigin -> Left, BaseStyle -> Bold],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}], "\n", 
 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"lHist", ",", "lBox"}], "}"}], ",", 
   RowBox[{"ImageSize", "->", "660"}], ",", 
   RowBox[{"Spacings", "->", "10"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.98195511573316*^9, 3.981955134758379*^9}, 
   3.9820932805327244`*^9, {3.9820950291382694`*^9, 3.982095053543333*^9}, 
   3.9820950941958275`*^9, {3.9820957589503*^9, 3.9820958546944904`*^9}},
