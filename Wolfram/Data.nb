exchange_nth_with_n_plus_1(lst):\n    # Iterate through the list with a step \
of 2\n    for i in range(0, len(lst) - 1, 2):\n        # Swap elements at \
index i and i+1\n        lst[i], lst[i + 1] = lst[i + 1], lst[i]\n    return \
lst\n\n# Example usage:\nexample_list = [1, 2, 3, 4, 5, 6]\nresult = \
exchange_nth_with_n_plus_1(example_list)\nprint(result)  # Output: [2, 1, 4, \
