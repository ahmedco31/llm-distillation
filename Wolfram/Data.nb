Cell["\<\
Look at the tight, completely isolated clusters for math_basic (magenta \
nablas), code_simple (green deltas), and knowledge (cyan rhombuses). The \
model isn\[CloseCurlyQuote]t just generating text; it is routing these \
queries to highly specialized, distinct regions of its \
\[OpenCurlyDoubleQuote]brain\[CloseCurlyDoubleQuote] (its latent space).\
\>", "Text",
 CellChangeTimes->{{3.981956875384247*^9, 3.9819568899828663`*^9}, {
   3.981957140210655*^9, 3.981957147398485*^9}, {3.9819572010306263`*^9, 
   3.9819572050320377`*^9}, 3.9819592243804073`*^9, {3.981959404129799*^9, 
   3.981959408249275*^9}, {3.9819594569159527`*^9, 3.9819594707897625`*^9}, {
   3.981959618867958*^9, 
   3.981959657742016*^9}},ExpressionUUID->"397d3c68-8fbc-bb49-a8a1-\
8f36b0b94f1f"],

Cell["\<\
Interestingly, the abstract prompts (orange circles) and logic_chain prompts \
(yellow squares) are broken into multiple tiny sub-clusters scattered around \
the edges. This tells us that \[OpenCurlyDoubleQuote]abstract\
\[CloseCurlyDoubleQuote] isn\[CloseCurlyQuote]t a single behavior to the LLM; \
it triggers several different internal semantic pathways.\
\>", "Text",
 CellChangeTimes->{{3.981956875384247*^9, 3.9819568899828663`*^9}, {
   3.981957140210655*^9, 3.981957147398485*^9}, {3.9819572010306263`*^9, 
   3.9819572050320377`*^9}, 3.981959226581417*^9, {3.981959671934675*^9, 
   3.9819596946335983`*^9}},ExpressionUUID->"617ff24a-cc62-7b4d-b49f-\
d52b171659d9"],

Cell["\<\
When a company (like DeepSeek) attempts to distill a frontier model (like \
OpenAI\[CloseCurlyQuote]s), they don\[CloseCurlyQuote]t just want random \
data. They need to systematically map and extract the entire semantic \
landscape. If an attacker only queried the green cluster (commonsense), their \
cloned student model would be completely incapable of writing code or doing \
math.\
\>", "Text",
 CellChangeTimes->{{3.981956875384247*^9, 3.9819568899828663`*^9}, {
  3.981957140210655*^9, 3.981957147398485*^9}, {3.9819572010306263`*^9, 
  3.9819572050320377`*^9}},ExpressionUUID->"417be27f-4c4a-ed4c-aa3f-\
c95f1178c706"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Infrastructure-level defense: timing-based anomaly detection", "Section",
 CellChangeTimes->{{3.9819619328577805`*^9, 3.9819619580747833`*^9}, {
  3.981962049581602*^9, 
  3.98196205974102*^9}},ExpressionUUID->"33af1631-987e-7d47-95fb-\
e9a3c81ffb28"],

Cell["\<\
A latency vs tokens total chart with anomalies highlighted by Isolation \
Forest. Normally with prompt complexity getting higher, the latency gets \
higher, that is why we see the linear trend of the data. Having points \
outside the trend such as low token, high latency points in top left or high \
token, high latency in top right indicates unusual behaviour that worth \
checking. Attackers cannot easily fake the math of how GPUs generate tokens, \
making this a good defense tool against model extraction.\
\>", "Text",
 CellChangeTimes->{3.981962087974064*^9, 
  3.9819621235963383`*^9},ExpressionUUID->"fe3db796-c1db-304c-ae84-\
5acb889c6307"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"latenciesBoth", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"data", "[", 
     RowBox[{"All", ",", "\"\<latency_ms\>\""}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tokens", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"data", "[", 
     RowBox[{"All", ",", "\"\<tokens_total\>\""}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"categories", "=", 
    RowBox[{"Normal", "[", 
     RowBox[{"data", "[", 
      RowBox[{"All", ",", "\"\<category\>\""}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nativeBlue", "=", 
   RowBox[{"ColorData", "[", 
    RowBox[{"97", ",", "1"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nativeRed", "=", 
   RowBox[{"ColorData", "[", 
    RowBox[{"97", ",", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"anomalyColors", "=", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"False", "->", "nativeBlue"}], ",", 
      RowBox[{"True", "->", "nativeRed"}]}], "|>"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"coords", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"tokens", ",", "latenciesBoth"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"latencyPerToken", "=", 
   RowBox[{"N", "[", 
    RowBox[{"latenciesBoth", "/", "tokens"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"features", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"latenciesBoth", ",", "tokens", ",", "latencyPerToken"}], "}"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"isAnomaly", "=", 
   RowBox[{"FindAnomalies", "[", 
    RowBox[{"features", ",", "\"\<AnomalyBooleanList\>\"", ",", 
     RowBox[{"AcceptanceThreshold", "->", "0.05"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataPoints", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"categories", ",", "isAnomaly", ",", "coords"}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"grouped", "=", 
   RowBox[{"GroupBy", "[", 
    RowBox[{"dataPoints", ",", 
     RowBox[{"First", "->", "Rest"}], ",", 
     RowBox[{"GroupBy", "[", 
      RowBox[{"First", "->", "Last"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"categoryShapes", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<abstract\>\"", "->", "\"\<\[FilledCircle]\>\""}], ",", 
     RowBox[{"\"\<code_simple\>\"", "->", "\"\<\[FilledSquare]\>\""}], ",", 
     RowBox[{"\"\<commonsense\>\"", "->", "\"\<\[FilledDiamond]\>\""}], ",", 
     RowBox[{"\"\<logic_chain\>\"", "->", "\"\<\[FilledUpTriangle]\>\""}], ",", 
     RowBox[{"\"\<math_basic\>\"", "->", "\"\<\[FilledDownTriangle]\>\""}]}], 
    "|>"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9819659672274227`*^9, 3.98196600272085*^9}, {
   3.9819660425308704`*^9, 3.981966045181446*^9}, 3.9820036083359756`*^9, {
   3.9820976589311714`*^9, 3.982097679303625*^9}, {3.982097940036564*^9, 
   3.9820980138686695`*^9}, {3.9820981880757046`*^9, 
   3.9820982379688377`*^9}, {3.982098489358576*^9, 3.982098541580288*^9}, {
   3.982098586379511*^9, 3.982098586717579*^9}, {3.982098629855335*^9, 
   3.9820986402286205`*^9}, {3.9820989272946224`*^9, 
   3.9820989338316536`*^9}, {3.982099119000799*^9, 3.9820991446345615`*^9}},
 CellLabel->
  "In[293]:=",ExpressionUUID->"5646ea0f-bfc2-8244-9dc7-ac399608a503"],

Cell[BoxData[
 RowBox[{
  RowBox[{"plots", "=", 
   RowBox[{"Flatten", "@", 
    RowBox[{"KeyValueMap", "[", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"cat", ",", "anomalyGroup"}], "}"}], ",", 
        RowBox[{"KeyValueMap", "[", 
         RowBox[{
          RowBox[{"Function", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"isAnom", ",", "points"}], "}"}], ",", 
            RowBox[{"ListPlot", "[", 
             RowBox[{"points", ",", 
              RowBox[{"PlotStyle", "->", 
               RowBox[{"anomalyColors", "[", "isAnom", "]"}]}], ",", 
              RowBox[{"PlotMarkers", "->", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"categoryShapes", "[", "cat", "]"}], ",", "10"}], 
                "}"}]}], ",", 
              RowBox[{"PlotLegends", "->", "None"}]}], "]"}]}], "]"}], ",", 
          "anomalyGroup"}], "]"}]}], "]"}], ",", "grouped"}], "]"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9819659672274227`*^9, 3.98196600272085*^9}, {
