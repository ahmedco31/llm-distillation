Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"anomalyPlot", "=", 
  RowBox[{"ListPlot", "[", 
   RowBox[{
    RowBox[{"Values", "[", "plotData", "]"}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"PointLegend", "[", 
      RowBox[{"Automatic", ",", 
       RowBox[{"Keys", "[", "plotData", "]"}], ",", 
       RowBox[{"LegendLabel", "->", "\"\<Category\>\""}]}], "]"}]}], ",", 
    RowBox[{"PlotMarkers", "->", "Automatic"}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"PointSize", "[", "0.015", "]"}]}], ",", 
    RowBox[{"PlotLabel", "->", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Anomaly Detection: Latency vs Token Count\>\"", ",", 
       "16"}], "]"}]}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<Total Tokens\>\"", ",", "\"\<Latency (ms)\>\""}], "}"}]}], 
    ",", 
    RowBox[{"PlotTheme", "->", "\"\<Detailed\>\""}], ",", 
    RowBox[{"ImageSize", "->", 
     RowBox[{"{", 
      RowBox[{"800", ",", "500"}], "}"}]}], ",", 
    RowBox[{"Epilog", "->", 
     RowBox[{"Inset", "[", 
