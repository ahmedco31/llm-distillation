ValueError(\\\"Position must be within the bounds of the array.\\\")\\n    \
\\n    # Reverse the subarray up to the given position\\n    arr[:position + \
1] = arr[:position + 1][::-1]\\n    return arr\\n\\n# Example \
usage:\\nmy_array = [1, 2, 3, 4, 5]\\nposition = 3\\nresult = \
reverse_array_up_to_position(my_array, position)\\nprint(result)  # Output: \
