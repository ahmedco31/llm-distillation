Cell[CellGroupData[{

Cell["Infrastructure-level defense: timing-based anomaly detection", "Section",
 CellChangeTimes->{{3.9819619328577805`*^9, 3.9819619580747833`*^9}, {
  3.981962049581602*^9, 
  3.98196205974102*^9}},ExpressionUUID->"33af1631-987e-7d47-95fb-\
e9a3c81ffb28"],

Cell["\<\
A latency vs tokens total chart with anomalies highlighted by Isolation \
Forest. Normally with prompt complexity getting higher, the latency gets \
higher, that is why we see the linear trend of the data. Having points \
outside the trend such as low token, high latency points in top left or high \
token, high latency in top right indicates unusual behaviour that worth \
checking. Attackers cannot easily fake the math of how GPUs generate tokens, \
making this a good defense tool against model extraction.\
\>", "Text",
 CellChangeTimes->{3.981962087974064*^9, 
  3.9819621235963383`*^9},ExpressionUUID->"fe3db796-c1db-304c-ae84-\
5acb889c6307"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tokens", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"data", "[", 
     RowBox[{"All", ",", "\"\<tokens_total\>\""}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"coords", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"tokens", ",", "latencies"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dataPoints", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"categories", ",", "isAnomaly", ",", "coords"}], "}"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9819625173696327`*^9, 3.981962555829956*^9}, 
   3.981963862803087*^9, 3.981964748206175*^9},
 CellLabel->
  "In[122]:=",ExpressionUUID->"3e99f661-c7d6-714c-9b0f-737a7405042b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"grouped", "=", 
   RowBox[{"GroupBy", "[", 
    RowBox[{"dataPoints", ",", 
     RowBox[{"First", "->", "Rest"}], ",", 
     RowBox[{"GroupBy", "[", 
      RowBox[{"First", "->", "Last"}], "]"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9819649433946056`*^9, 3.9819649606068516`*^9}, 
   3.981964996510784*^9},
 CellLabel->
  "In[125]:=",ExpressionUUID->"0f75b8ef-d4e9-6145-8b62-5fd703a0a3b0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"categoryShapes", "=", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{"DeleteDuplicates", "[", "categories", "]"}], "->", 
     RowBox[{"{", 
      RowBox[{"\"\<\[FilledCircle]\>\"", ",", "\"\<\[FilledSquare]\>\"", 
       ",", "\"\<\[FilledDiamond]\>\"", ",", "\"\<\[FilledUpTriangle]\>\"", 
       ",", "\"\<\[FilledDownTriangle]\>\""}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"anomalyColors", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"False", "->", 
      RowBox[{"ColorData", "[", 
       RowBox[{"97", ",", "1"}], "]"}]}], ",", 
     RowBox[{"True", "->", 
      RowBox[{"ColorData", "[", 
       RowBox[{"97", ",", "2"}], "]"}]}]}], "|>"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9819650089297886`*^9, 3.981965008930788*^9}, {
  3.9819657050633965`*^9, 3.9819657105005016`*^9}},
 CellLabel->
  "In[126]:=",ExpressionUUID->"829225de-d7b5-4042-935c-d2555cd39792"],

Cell[BoxData[
 RowBox[{
  RowBox[{"plots", "=", 
   RowBox[{"Flatten", "@", 
    RowBox[{"KeyValueMap", "[", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"cat", ",", "anomalyGroup"}], "}"}], ",", 
        RowBox[{"KeyValueMap", "[", 
         RowBox[{
          RowBox[{"Function", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"isAnom", ",", "points"}], "}"}], ",", 
            RowBox[{"ListPlot", "[", 
             RowBox[{"points", ",", 
              RowBox[{"PlotStyle", "->", 
               RowBox[{"anomalyColors", "[", "isAnom", "]"}]}], ",", 
              RowBox[{"PlotMarkers", "->", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"categoryShapes", "[", "cat", "]"}], ",", "10"}], 
                "}"}]}], ",", 
              RowBox[{"PlotLegends", "->", "None"}]}], "]"}]}], "]"}], ",", 
          "anomalyGroup"}], "]"}]}], "]"}], ",", "grouped"}], "]"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9819647849933376`*^9, 3.9819647849933376`*^9}, 
   3.9819650215829277`*^9},
 CellLabel->
  "In[128]:=",ExpressionUUID->"dad623b1-152c-6845-9921-6f37be31c17e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Legended", "[", 
  RowBox[{
   RowBox[{"Show", "[", 
    RowBox[{"plots", ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Anomaly Detection: Latency vs Token Count\>\"", ",", 
        "16"}], "]"}]}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Total Tokens\>\"", ",", "\"\<Latency (ms)\>\""}], "}"}]}],
      ",", 
     RowBox[{"PlotTheme", "->", "\"\<Detailed\>\""}], ",", 
     RowBox[{"ImageSize", "->", 
      RowBox[{"{", 
       RowBox[{"500", ",", "500"}], "}"}]}]}], "]"}], ",", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"The", " ", "Custom", " ", "dual"}], "-", "legend"}], "*)"}], 
   RowBox[{"Placed", "[", 
    RowBox[{
     RowBox[{"Grid", "[", 
      RowBox[{
       RowBox[{"{", 
