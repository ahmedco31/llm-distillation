Cell["\<\
Latency by category: extract categories and group the latencies by category \
\>", "Text",
 CellChangeTimes->{{3.9819555133316193`*^9, 
  3.9819555276270885`*^9}},ExpressionUUID->"b90acac4-1788-8044-b581-\
0c83799a90ad"],

Cell[BoxData[
 RowBox[{
  RowBox[{"latencyByCategory", "=", 
   RowBox[{"GroupBy", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Normal", "[", 
         RowBox[{"data", "[", 
          RowBox[{"All", ",", "\"\<category\>\""}], "]"}], "]"}], ",", 
        "latencies"}], "}"}], "]"}], ",", 
     RowBox[{"First", "->", "Last"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981955554687523*^9, 3.981955560093815*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"e17f940e-b982-2d4a-82f3-05d1c02bf178"],

Cell[BoxData[
 RowBox[{
  RowBox[{"lBox", "=", 
   RowBox[{"BoxWhiskerChart", "[", 
    RowBox[{
     RowBox[{"Values", "[", "latencyByCategory", "]"}], ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["6", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["704", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      ChartLabels -> Keys[$CellContext`latencyByCategory], PlotLabel -> 
       "Response Latency by Category", 
       AxesLabel -> {"Category", "Latency (ms)"}, PlotTheme -> "Detailed", 
       BarOrigin -> Left, BaseStyle -> Bold],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981955572470644*^9, 3.981955583399828*^9}, {
