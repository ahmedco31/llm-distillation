Cell[BoxData[{
 RowBox[{
  RowBox[{"responses", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"data", "[", 
     RowBox[{"All", ",", "\"\<response\>\""}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"wordCounts", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Length", "[", 
      RowBox[{"StringSplit", "[", "#", "]"}], "]"}], "&"}], "/@", 
    "responses"}]}], ";"}]}], "Input",
