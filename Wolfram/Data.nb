Cell[CellGroupData[{

Cell["Query Pattern Analysis", "Section",
 CellChangeTimes->{
  3.9817506230555344`*^9},ExpressionUUID->"dfc3fdc6-49e3-464f-adc1-\
2bf52084dec2"],

Cell[TextData[{
 "I understand now why attackers add a randomly-lengthed intervals between \
queries, to mimic human behaviour when interacting with AI and avoid \
detection. When I made a fixed 20 seconds interval between queries, ",
 StyleBox["the histogram of inter-query intervals gives me away immediately",
  FontWeight->"Bold"],
 ". The variation in server response latency creates the skew we see in the \
histogram. The boxplot shows that the API\[CloseCurlyQuote]s response latency \
is fundamentally tied to the category of the query, rather than the length of \
the query interval."
}], "Text",
 CellChangeTimes->{{3.981750629835079*^9, 
  3.9817506585628147`*^9}},ExpressionUUID->"921601e4-4ab3-a24b-bdc9-\
be9b50029331"],

Cell["\<\
Would seeing the server processing time regularly spikes to 5000ms raises a \
red flag even though inter-query timing looks random?\
\>", "Text",
 CellChangeTimes->{
  3.9817507125251465`*^9},ExpressionUUID->"f6948a1c-4824-8a46-ab61-\
c746cd93b895"],

Cell["\<\
Extract timestamps, convert to seconds since 1900, sort, and calculate \
differences\
\>", "Text",
 CellChangeTimes->{
  3.981955009548931*^9},ExpressionUUID->"c9923437-9781-8d44-812f-\
9be731a7e16c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"intervals", "=", 
   RowBox[{"Differences", "@", 
    RowBox[{"Sort", "@", 
     RowBox[{"N", "[", 
      RowBox[{"AbsoluteTime", "/@", 
       RowBox[{"Normal", "[", 
        RowBox[{"data", "[", 
         RowBox[{"All", ",", "\"\<timestamp\>\""}], "]"}], "]"}]}], 
      "]"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.98195511573316*^9, 3.981955134758379*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"654e8c08-7d92-164a-af5d-1aa0e398f919"],

Cell[BoxData[
 RowBox[{
  RowBox[{"medianInterval", "=", 
   RowBox[{"Median", "@", "intervals"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9819550424557953`*^9, 3.981955069535145*^9}, {
  3.9819551513436604`*^9, 3.9819551520593815`*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"04e13ede-19a4-1847-b5bd-c9f39c8550cd"],

Cell["Latencies and their mean", "Text",
 CellChangeTimes->{{3.981955209458727*^9, 
  3.9819552430952244`*^9}},ExpressionUUID->"d0d544cc-2f82-6a4a-9ad5-\
87e8f4d524f3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"latencies", "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"data", "[", 
     RowBox[{"All", ",", "\"\<latency_ms\>\""}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"meanLatency", "=", 
   RowBox[{"Mean", "[", 
    RowBox[{"N", "@", "latencies"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.981955253108698*^9, 3.981955260854641*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"511af730-575f-1647-8b05-3a309a6c9cc7"],

Cell["Histogram vis.", "Text",
 CellChangeTimes->{{3.9819552746897354`*^9, 
  3.981955288794632*^9}},ExpressionUUID->"1d4654c4-7422-3e45-ad8c-\
c627d973e35c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"lHist", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"intervals", ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["10", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["1520", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      30, PlotLabel -> "Inter-Query Intervals", 
       AxesLabel -> {"Seconds Between Queries", "Frequency"}, ChartStyle -> 
       EdgeForm[Black], PlotTheme -> "Detailed", 
       GridLines -> {{$CellContext`medianInterval}, None}, GridLinesStyle -> 
       Directive[Red, Dashed, 
         Thickness[0.005]], BaseStyle -> Bold, ChartLegends -> Placed[
         LineLegend[{
           Directive[Red, Dashed]}, {"Median"}], {Right, Top}], ImageSize -> 
       300],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9819553148143673`*^9, 3.98195532004298*^9}, {
   3.9819554372788696`*^9, 3.9819554434602375`*^9}, {3.981955484786438*^9, 
   3.9819554866151676`*^9}, {3.98195564264476*^9, 3.9819556615870075`*^9}, 
