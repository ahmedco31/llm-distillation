Cell[CellGroupData[{

Cell["Query Pattern Analysis", "Section",
 CellChangeTimes->{
  3.9817506230555344`*^9},ExpressionUUID->"dfc3fdc6-49e3-464f-adc1-\
2bf52084dec2"],

Cell[TextData[{
 "I understand now why attackers add a randomly-lengthed intervals between \
queries, to mimic human behaviour when interacting with AI and avoid \
detection. When I made a fixed 20 seconds interval between queries from \
gpt-4o-mini, ",
 StyleBox["the histogram of inter-query intervals gives me away immediately",
  FontWeight->"Bold"],
 ". The variation in server response latency creates the skew we see in the \
histogram. The boxplot shows that the API\[CloseCurlyQuote]s response latency \
is fundamentally tied to the category of the query, rather than the length of \
the query interval.\n",
 StyleBox["On the other side in gpt-4o data the intervals are randomised to \
bypass this giveaway and smoothed the histogram.",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.981750629835079*^9, 3.9817506585628147`*^9}, {
  3.982092845265524*^9, 3.982092860106888*^9}, {3.9820932276935673`*^9, 
  3.9820932661469784`*^9}, {3.9820953511305656`*^9, 3.982095397456215*^9}, {
  3.9820954334206295`*^9, 
  3.982095433764929*^9}},ExpressionUUID->"921601e4-4ab3-a24b-bdc9-\
be9b50029331"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"dataMini", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"data", ",", 
     RowBox[{
      RowBox[{"#model", "==", "\"\<gpt-4o-mini\>\""}], "&"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"data4o", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"data", ",", 
     RowBox[{
      RowBox[{"#model", "==", "\"\<gpt-4o\>\""}], "&"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9820929421704865`*^9, 3.9820929421704865`*^9}, {
  3.982093033351763*^9, 3.982093038038624*^9}},
 CellLabel->
  "In[113]:=",ExpressionUUID->"8aea9adc-4cc6-f148-ba39-ebdfbe44dd04"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Column", "@", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Dimensions", "@", "data4o"}], ",", 
    RowBox[{"Dimensions", "@", "dataMini"}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.982092949348093*^9, 3.982092959353649*^9}, {
  3.982093060807516*^9, 3.982093103817692*^9}},
 CellLabel->
  "In[115]:=",ExpressionUUID->"45b824ce-fa0a-ca4e-b395-59f6a345001f"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     RowBox[{"{", 
      RowBox[{"1200", ",", "17"}], "}"}]},
    {
     RowBox[{"{", 
      RowBox[{"400", ",", "17"}], "}"}]}
   },
   DefaultBaseStyle->"Column",
   GridBoxAlignment->{"Columns" -> {{Left}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Column"]], "Output",
 CellChangeTimes->{{3.9820929551267033`*^9, 3.982092959658827*^9}, {
   3.982093049238737*^9, 3.9820930614098854`*^9}, {3.9820930944697304`*^9, 
   3.9820931042334023`*^9}, 3.9820943869274025`*^9, 3.9820944623225517`*^9, 
   3.9820956788931656`*^9},
 CellLabel->
  "Out[115]=",ExpressionUUID->"cce3a327-3323-1947-8e7c-5a720a611c57"]
}, Open  ]],

Cell["\<\
Extract timestamps, convert to seconds since 1900, sort, and calculate \
differences\
\>", "Text",
 CellChangeTimes->{
  3.981955009548931*^9},ExpressionUUID->"c9923437-9781-8d44-812f-\
9be731a7e16c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"intervals", "=", 
   RowBox[{"Differences", "@", 
    RowBox[{"Sort", "@", 
     RowBox[{"N", "[", 
      RowBox[{"AbsoluteTime", "/@", 
       RowBox[{"Normal", "[", 
        RowBox[{"dataMini", "[", 
         RowBox[{"All", ",", "\"\<timestamp\>\""}], "]"}], "]"}]}], 
      "]"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.98195511573316*^9, 3.981955134758379*^9}, 
   3.9820932805327244`*^9},
 CellLabel->
  "In[140]:=",ExpressionUUID->"654e8c08-7d92-164a-af5d-1aa0e398f919"],

Cell[BoxData[
 RowBox[{
  RowBox[{"medianInterval", "=", 
   RowBox[{"Median", "@", "intervals"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9819550424557953`*^9, 3.981955069535145*^9}, {
  3.9819551513436604`*^9, 3.9819551520593815`*^9}},
 CellLabel->
  "In[141]:=",ExpressionUUID->"04e13ede-19a4-1847-b5bd-c9f39c8550cd"],

Cell["\<\
Latencies and their mean. Making sure we remove outliers that are due to \
connection error.\
\>", "Text",
 CellChangeTimes->{{3.981955209458727*^9, 3.9819552430952244`*^9}, {
  3.9820943281170025`*^9, 
  3.9820943531449566`*^9}},ExpressionUUID->"d0d544cc-2f82-6a4a-9ad5-\
87e8f4d524f3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"latencies", "=", 
   RowBox[{"DeleteAnomalies", "@", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Normal", "[", 
        RowBox[{"dataMini", "[", 
         RowBox[{"All", ",", "\"\<category\>\""}], "]"}], "]"}], ",", 
       RowBox[{"Normal", "[", 
        RowBox[{"dataMini", "[", 
         RowBox[{"All", ",", "\"\<latency_ms\>\""}], "]"}], "]"}]}], "}"}], 
     "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9820947328404503`*^9, 3.9820947328404503`*^9}, {
   3.98209487173872*^9, 3.982094873375683*^9}, 3.9820949233519*^9},
 CellLabel->
  "In[142]:=",ExpressionUUID->"9b9a7fd9-3bce-0a44-8cf7-3e5d1c3aa159"],

Cell[BoxData[
 RowBox[{
  RowBox[{"meanLatency", "=", 
   RowBox[{"Mean", "[", 
    RowBox[{"N", "@", "latencies"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981955253108698*^9, 3.981955260854641*^9}, 
   3.982093287465826*^9, 3.9820938043273945`*^9},
 CellLabel->
  "In[143]:=",ExpressionUUID->"e52d24eb-cdc0-b44b-bff5-8e67426fb43e"],

Cell["Histogram vis.", "Text",
 CellChangeTimes->{{3.9819552746897354`*^9, 
  3.981955288794632*^9}},ExpressionUUID->"1d4654c4-7422-3e45-ad8c-\
c627d973e35c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"lHist", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"intervals", ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["10", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["1544", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      30, PlotLabel -> "Inter-Query Intervals (fixed, gpt-4o-mini)", 
       AxesLabel -> {"Seconds Between Queries", "Frequency"}, ChartStyle -> 
       EdgeForm[Black], PlotTheme -> "Detailed", 
       GridLines -> {{$CellContext`medianInterval}, None}, GridLinesStyle -> 
       Directive[Red, Dashed, 
         Thickness[0.005]], BaseStyle -> Bold, ChartLegends -> Placed[
         LineLegend[{
           Directive[Red, Dashed]}, {"Median"}], {Right, Top}], ImageSize -> 
       300],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9819553148143673`*^9, 3.98195532004298*^9}, {
   3.9819554372788696`*^9, 3.9819554434602375`*^9}, {3.981955484786438*^9, 
   3.9819554866151676`*^9}, {3.98195564264476*^9, 3.9819556615870075`*^9}, 
   3.981955763446575*^9, {3.981955990933859*^9, 3.981956009601259*^9}, {
   3.981956056538391*^9, 3.981956070520296*^9}, {3.9819561067490807`*^9, 
   3.9819561342081223`*^9}, {3.9820956714585667`*^9, 3.9820957423096027`*^9}},
 CellLabel->
  "In[144]:=",ExpressionUUID->"f80f8e71-8560-cd44-891b-2b53c117515a"],

Cell["\<\
Latency by category: extract categories and group the latencies by category \
\>", "Text",
 CellChangeTimes->{{3.9819555133316193`*^9, 
  3.9819555276270885`*^9}},ExpressionUUID->"b90acac4-1788-8044-b581-\
0c83799a90ad"],

Cell[BoxData[
 RowBox[{
  RowBox[{"latencyByCategory", "=", 
   RowBox[{"GroupBy", "[", 
    RowBox[{"latencies", ",", 
     RowBox[{"First", "->", "Last"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981955554687523*^9, 3.981955560093815*^9}, 
   3.9820932992396603`*^9, 3.9820949863655224`*^9},
 CellLabel->
  "In[145]:=",ExpressionUUID->"e17f940e-b982-2d4a-82f3-05d1c02bf178"],

Cell[BoxData[
 RowBox[{
  RowBox[{"lBox", "=", 
   RowBox[{"BoxWhiskerChart", "[", 
    RowBox[{
     RowBox[{"Values", "[", "latencyByCategory", "]"}], ",", 
     InterpretationBox[
      DynamicModuleBox[{Typeset`open = False}, 
       TemplateBox[{"Expression", "SequenceIcon", 
         GridBox[{{
            RowBox[{
              TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["Sequence", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
              TagBox["6", "IconizedItem"]}]}, {
            RowBox[{
              TagBox["\"Byte count: \"", "IconizedLabel"], 
              "\[InvisibleSpace]", 
              TagBox["720", "IconizedItem"]}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
          "Column", 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
         Dynamic[Typeset`open]},
        "IconizedObject"]],
      Sequence[
      ChartLabels -> Keys[$CellContext`latencyByCategory], PlotLabel -> 
       "Response Latency by Category (gpt-4o-mini)", 
       AxesLabel -> {"Category", "Latency (ms)"}, PlotTheme -> "Detailed", 
       BarOrigin -> Left, BaseStyle -> Bold],
      SelectWithContents->True,
      Selectable->False]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981955572470644*^9, 3.981955583399828*^9}, {
   3.9819556295501785`*^9, 3.9819556375084457`*^9}, {3.9819556905191975`*^9, 
